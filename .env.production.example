# Frontend (Vercel)
VITE_API_MODE=real
VITE_API_BASE_URL=https://api.your-domain.com/api
VITE_MARKETING_SHARE_BASE_URL=https://mini.your-domain.com
VITE_MARKETING_RECOMMENDATION_IMAGES=https://cdn.your-domain.com/marketing/recommendation-1.jpg,https://cdn.your-domain.com/marketing/recommendation-2.jpg
VITE_MARKETING_POSTER_IMAGE_1=https://cdn.your-domain.com/marketing/poster-1.jpg
VITE_MARKETING_POSTER_IMAGE_2=https://cdn.your-domain.com/marketing/poster-2.jpg
VITE_MARKETING_POSTER_IMAGE_3=https://cdn.your-domain.com/marketing/poster-3.jpg

# Backend (Railway/Render)
DATABASE_URL=postgresql://user:password@host:5432/beauty_salon?sslmode=require
REDIS_URL=redis://default:password@host:6379
JWT_SECRET=<generate-with-openssl-rand-base64-32>
JWT_REFRESH_SECRET=<generate-with-openssl-rand-base64-32>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_PRINCIPAL_CACHE_TTL_MS=5000
CORS_ORIGINS=https://your-domain.vercel.app
REQUEST_BODY_LIMIT=12mb
MARKETING_RECOMMENDATION_IMAGE_URL=https://cdn.your-domain.com/marketing/default-recommendation.jpg
MARKETING_RECOMMENDATION_INSTANCE_WRITE=true
MARKETING_RECOMMENDATION_INSTANCE_READ=false
MARKETING_RECOMMENDATION_ADOPTION_V2=false
MARKETING_DELIVERY_JOB_ENGINE=false
MARKETING_EFFECT_FACT_WRITE=false
MARKETING_EFFECT_FACT_READ=false
# Example: 6 for demo-store-only rollout; * enables configured flags for every store.
MARKETING_ROLLOUT_STORE_IDS=6
ADMIN_DEFAULT_PASSWORD=<set-only-for-production-seed>
DEMO_USER_DEFAULT_PASSWORD=<set-only-for-demo-seed>
LLM_PROVIDER=kimi
LLM_API_KEY=
# Optional: resolve the key from another environment variable instead of duplicating it here.
LLM_API_KEY_ENV=
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_CHAT_PATH=/chat/completions
LLM_MODEL=kimi-k2.7-code-highspeed
LLM_TEMPERATURE=1
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_MS=60000
LLM_STREAM=false
LLM_THINKING=enabled
LLM_REASONING_EFFORT=high
LLM_DAILY_BUDGET=50
# Structured output: auto/json_schema/json_object. auto uses json_object for generic OpenAI-compatible providers.
# deepseek and kimi always use json_object; only explicit json_schema enables strict json_schema where supported.
LLM_STRUCTURED_OUTPUT_MODE=auto
LLM_STRUCTURED_MAX_TOTAL_TOKENS=8192
LLM_FALLBACK_PROVIDER=deepseek
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_API_KEY_ENV=
LLM_FALLBACK_BASE_URL=https://api.deepseek.com
LLM_FALLBACK_CHAT_PATH=/chat/completions
LLM_FALLBACK_MODEL=deepseek-v4-flash
LLM_FALLBACK_TIMEOUT_MS=30000
LLM_FALLBACK_STRUCTURED_OUTPUT_MODE=auto
LLM_FALLBACK_STRUCTURED_MAX_TOTAL_TOKENS=8192

# Ami Brain production-safe defaults. Enable model rollout only after release gates pass.
BRAIN_COGNITION_MODE=rules
BRAIN_PLANNER_MODE=rules
BRAIN_MODEL_SHADOW_PERCENT=0
BRAIN_MODEL_CANARY_PERCENT=0
BRAIN_MODEL_MIN_CONFIDENCE=0.85
BRAIN_CAPABILITY_TOP_K=8
BRAIN_CAPABILITY_MIN_CONFIDENCE=0.3
BRAIN_MAX_PLAN_NODES=8
BRAIN_MAX_REPLANS=2
BRAIN_TOTAL_TIMEOUT_MS=20000
BRAIN_MODEL_TIMEOUT_MS=8000
BRAIN_SINGLE_TOOL_FAST_PATH=true
BRAIN_ALLOW_CANDIDATE_INSPECTION_GUARDS=false
BRAIN_GOVERNANCE_SYSTEM_USER_ID=
# Disabled by default. Enable only after semantic worker gates and review workflow are verified.
BRAIN_SEMANTIC_EVIDENCE_WORKER_ENABLED=false
BRAIN_SEMANTIC_EVIDENCE_BATCH_SIZE=100
# Positive user id required for automatic validation and publish; blank keeps candidates in review.
BRAIN_SEMANTIC_AUTOMATION_USER_ID=
# Disabled by default. Enable only after the regeneration job migration and governance gates are verified.
BRAIN_CAPABILITY_REGENERATION_WORKER_ENABLED=false
BRAIN_CAPABILITY_WORKSPACE_ROOT=

# Agent V2 治理、灰度与自动发布
# deploy hook URL 示例：https://api.your-domain.com/api/agent-v2/capability-center/auto-publish/deploy-hook
AGENT_V2_DEPLOY_HOOK_URL=
AGENT_V2_AUTO_PUBLISH_DEPLOY_TOKEN=<generate-with-openssl-rand-base64-32>
# 仅在部署平台后端 env 已设置同轮 token 且 health 可达后改为 true；用于生产 hook smoke 前审计，不读取 Secret 明文。
AGENT_V2_PRODUCTION_BACKEND_ENV_CONFIRMED=false
# 当前策略：由 GitHub main 分支提交后的 workflow 触发 auto-publish hook；平时不启用后端定时自动发布。
AGENT_V2_AUTO_PUBLISH_CRON=false
# git_diff 扫描的对比基准，例如 origin/main 或上一次部署 tag。
AGENT_V2_AUTO_PUBLISH_BASE_REF=origin/main
# 默认保持旧链路或由治理表配置灰度；不建议生产全局直接 kg_llm_only。
AGENT_V2_GRAY_MODE=legacy_regex
AGENT_V2_GRAY_RULES=
AGENT_LLM_TASK_COMPILER_ENABLED=true
# 只有生产证据校验、7 天 shadow、线上有用率和回滚验证全部通过后才允许改为 true。
AGENT_V2_LEGACY_RETIREMENT_CONFIRMED=false
# 兼容旧意图引擎开关；生产建议保持 legacy_regex，由治理表或 AGENT_V2_GRAY_MODE 控制灰度。
AGENT_INTENT_ENGINE=legacy_regex
# true 会进入 shadow 对比；生产开启前需先确认观测、成本和回滚口径。
AGENT_INTENT_SHADOW_COMPARE=false

# Agent V2 controlled Text-to-SQL production contract
AGENT_V2_TEXT_TO_SQL_ENABLED=false
AGENT_V2_TEXT_TO_SQL_ADMIN_ONLY=true
AGENT_V2_TEXT_TO_SQL_MAX_LIMIT=100
AGENT_V2_TEXT_TO_SQL_TIMEOUT_MS=5000
AGENT_V2_TEXT_TO_SQL_MAX_RANGE_DAYS=365
AGENT_V2_TEXT_TO_SQL_MAX_ESTIMATED_COST=100000
# Must use an independent readonly PostgreSQL account. Never reuse DATABASE_URL.
AGENT_V2_TEXT_TO_SQL_READONLY_DATABASE_URL=

# Face++ 皮肤分析-高阶版，仅配置在 Core API 后端
FACEPP_API_KEY=
FACEPP_API_SECRET=
FACEPP_SKIN_ANALYZE_URL=https://api-cn.faceplusplus.com/facepp/v1/skinanalyze
FACEPP_SKIN_ANALYZE_TIMEOUT_MS=30000
FACEPP_SKIN_ANALYZE_FALLBACK=true
NODE_ENV=production
PORT=3000
