# Frontend (Vercel)
VITE_API_MODE=real
VITE_API_BASE_URL=https://api.your-domain.com/api
VITE_MARKETING_SHARE_BASE_URL=https://mini.your-domain.com
VITE_MARKETING_RECOMMENDATION_IMAGES=https://cdn.your-domain.com/marketing/recommendation-1.jpg,https://cdn.your-domain.com/marketing/recommendation-2.jpg
VITE_MARKETING_POSTER_IMAGE_1=https://cdn.your-domain.com/marketing/poster-1.jpg
VITE_MARKETING_POSTER_IMAGE_2=https://cdn.your-domain.com/marketing/poster-2.jpg
VITE_MARKETING_POSTER_IMAGE_3=https://cdn.your-domain.com/marketing/poster-3.jpg

# Backend (Railway/Render)
DATABASE_URL=postgresql://user:password@host:5432/beauty_salon?sslmode=require
REDIS_URL=redis://default:password@host:6379
JWT_SECRET=<generate-with-openssl-rand-base64-32>
JWT_REFRESH_SECRET=<generate-with-openssl-rand-base64-32>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CORS_ORIGINS=https://your-domain.vercel.app
REQUEST_BODY_LIMIT=12mb
MARKETING_RECOMMENDATION_IMAGE_URL=https://cdn.your-domain.com/marketing/default-recommendation.jpg
ADMIN_DEFAULT_PASSWORD=<set-only-for-production-seed>
DEMO_USER_DEFAULT_PASSWORD=<set-only-for-demo-seed>
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_PATH=/chat/completions
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_TIMEOUT_MS=30000
LLM_STREAM=false
LLM_THINKING=disabled
LLM_REASONING_EFFORT=high
LLM_DAILY_BUDGET=50

# Agent V2 治理、灰度与自动发布
# deploy hook URL 示例：https://api.your-domain.com/api/agent-v2/capability-center/auto-publish/deploy-hook
AGENT_V2_DEPLOY_HOOK_URL=
AGENT_V2_AUTO_PUBLISH_DEPLOY_TOKEN=<generate-with-openssl-rand-base64-32>
# 仅在部署平台后端 env 已设置同轮 token 且 health 可达后改为 true；用于生产 hook smoke 前审计，不读取 Secret 明文。
AGENT_V2_PRODUCTION_BACKEND_ENV_CONFIRMED=false
# 当前策略：由 GitHub main 分支提交后的 workflow 触发 auto-publish hook；平时不启用后端定时自动发布。
AGENT_V2_AUTO_PUBLISH_CRON=false
# git_diff 扫描的对比基准，例如 origin/main 或上一次部署 tag。
AGENT_V2_AUTO_PUBLISH_BASE_REF=origin/main
# 默认保持旧链路或由治理表配置灰度；不建议生产全局直接 kg_llm_only。
AGENT_V2_GRAY_MODE=legacy_regex
AGENT_V2_GRAY_RULES=
# 只有生产证据校验、7 天 shadow、线上有用率和回滚验证全部通过后才允许改为 true。
AGENT_V2_LEGACY_RETIREMENT_CONFIRMED=false
# 兼容旧意图引擎开关；生产建议保持 legacy_regex，由治理表或 AGENT_V2_GRAY_MODE 控制灰度。
AGENT_INTENT_ENGINE=legacy_regex
# true 会进入 shadow 对比；生产开启前需先确认观测、成本和回滚口径。
AGENT_INTENT_SHADOW_COMPARE=false

# Face++ 皮肤分析-高阶版，仅配置在 Core API 后端
FACEPP_API_KEY=
FACEPP_API_SECRET=
FACEPP_SKIN_ANALYZE_URL=https://api-cn.faceplusplus.com/facepp/v1/skinanalyze
FACEPP_SKIN_ANALYZE_TIMEOUT_MS=30000
FACEPP_SKIN_ANALYZE_FALLBACK=true
NODE_ENV=production
PORT=3000
