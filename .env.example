# Frontend local development
VITE_API_MODE=real
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8080
VITE_MARKETING_SHARE_BASE_URL=https://mini.ami-core.com
VITE_MARKETING_RECOMMENDATION_IMAGES=
VITE_MARKETING_POSTER_IMAGE_1=
VITE_MARKETING_POSTER_IMAGE_2=
VITE_MARKETING_POSTER_IMAGE_3=

# Playwright / E2E
E2E_BASE_URL=http://127.0.0.1:55173
E2E_HOST=127.0.0.1
E2E_PORT=55173
E2E_USERNAME=admin
E2E_PASSWORD=11111111

# Backend local development
DATABASE_URL=postgresql://user:password@localhost:5432/beauty_salon
JWT_SECRET=local-dev-secret-change-me
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5175
REQUEST_BODY_LIMIT=12mb
PORT=8080
MARKETING_RECOMMENDATION_IMAGE_URL=https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=400

# Local seed defaults. Production must set explicit non-default values.
ADMIN_DEFAULT_PASSWORD=11111111
DEMO_USER_DEFAULT_PASSWORD=11111111

# AI Gateway local defaults. Kimi key is backend-only; keep it empty locally until configured.
LLM_PROVIDER=kimi
LLM_API_KEY=
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_CHAT_PATH=/chat/completions
LLM_MODEL=kimi-k2.7-code-highspeed
LLM_TEMPERATURE=1
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_MS=60000
LLM_STREAM=false
LLM_THINKING=enabled
LLM_REASONING_EFFORT=high
LLM_DAILY_BUDGET=0

# Optional fallback provider. Leave key empty unless fallback is enabled.
LLM_FALLBACK_PROVIDER=deepseek
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=https://api.deepseek.com
LLM_FALLBACK_CHAT_PATH=/chat/completions
LLM_FALLBACK_MODEL=deepseek-v4-flash
LLM_FALLBACK_TIMEOUT_MS=30000

# Agent V2 controlled Text-to-SQL local defaults
# Local development can enable dry-run / guard inspect without a readonly DB URL.
# Production should set this explicitly and only enable execute after strict readiness.
AGENT_V2_TEXT_TO_SQL_ENABLED=true
AGENT_V2_TEXT_TO_SQL_ADMIN_ONLY=true
AGENT_V2_TEXT_TO_SQL_MAX_LIMIT=100
AGENT_V2_TEXT_TO_SQL_TIMEOUT_MS=5000
AGENT_V2_TEXT_TO_SQL_MAX_RANGE_DAYS=365
AGENT_V2_TEXT_TO_SQL_MAX_ESTIMATED_COST=100000
AGENT_LLM_TASK_COMPILER_ENABLED=true
# Reserved for gray/prod execute: use an independent readonly Postgres user/connection.
# Empty means local dry-run only; never point this at DATABASE_URL.
AGENT_V2_TEXT_TO_SQL_READONLY_DATABASE_URL=

# Face++ is configured only on the backend.
FACEPP_API_KEY=
FACEPP_API_SECRET=
FACEPP_SKIN_ANALYZE_URL=https://api-cn.faceplusplus.com/facepp/v1/skinanalyze
FACEPP_SKIN_ANALYZE_TIMEOUT_MS=30000
FACEPP_SKIN_ANALYZE_FALLBACK=true
