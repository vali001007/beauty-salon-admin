{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["miniprogram/*"]
    },
    "types": []
  },
  "include": ["miniprogram/**/*.ts", "miniprogram/**/*.d.ts"]
}
