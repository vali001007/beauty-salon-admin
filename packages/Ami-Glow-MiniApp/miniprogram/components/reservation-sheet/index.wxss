.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  background: rgba(48, 33, 58, 0.18);
  align-items: flex-end;
}

.sheet {
  width: 100%;
  max-height: 88vh;
  padding: 0 40rpx 48rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #fff;
  overflow-y: auto;
}

.sheet-header {
  display: flex;
  height: 124rpx;
  border-bottom: 2rpx solid #ead6ef;
  align-items: center;
  justify-content: space-between;
  color: #33283f;
  font-size: 36rpx;
  font-weight: 700;
}

.close {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5eef7;
  color: #8d7a93;
  font-size: 54rpx;
  line-height: 68rpx;
}

.field {
  margin-top: 42rpx;
}

.label {
  margin-bottom: 20rpx;
  color: #3a2e48;
  font-size: 32rpx;
  font-weight: 700;
}

.readonly {
  height: 94rpx;
  padding: 0 42rpx;
  border-radius: 18rpx;
  background: #d7d3d8;
  color: #9b8fa0;
  font-size: 30rpx;
  line-height: 94rpx;
}

.beautician-row {
  width: 100%;
  white-space: nowrap;
}

.beautician {
  display: inline-block;
  min-width: 150rpx;
  height: 74rpx;
  margin-right: 18rpx;
  padding: 0 24rpx;
  border: 2rpx solid #ead6ef;
  border-radius: 18rpx;
  color: #3a2e48;
  line-height: 74rpx;
  text-align: center;
}

.beautician.active,
.day.active,
.slot.active {
  background: linear-gradient(135deg, #a967ce, #dba1eb);
  color: #fff;
}

.time-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.week-btn {
  display: inline-block;
  width: 116rpx;
  height: 50rpx;
  margin-left: 14rpx;
  border-radius: 999rpx;
  background: #f2e6f6;
  color: #a967ce;
  font-size: 24rpx;
  line-height: 50rpx;
}

.week-btn.disabled {
  background: #eeeeee;
  color: #b8b8b8;
}

.week-row {
  display: flex;
  padding: 16rpx;
  border: 2rpx solid #ead6ef;
  border-radius: 22rpx;
  background: #faeffc;
}

.day {
  flex: 1;
  min-width: 0;
  height: 86rpx;
  border-radius: 18rpx;
  color: #111;
  font-size: 24rpx;
  text-align: center;
}

.day text {
  display: block;
  line-height: 42rpx;
}

.slot-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
  margin-top: 26rpx;
}

.slot {
  height: 64rpx;
  border: 2rpx solid #ead6ef;
  border-radius: 18rpx;
  color: #3a2e48;
  line-height: 64rpx;
  text-align: center;
}

.slot.disabled {
  background: #f0edf1;
  color: #b9b1bd;
}

.primary-button {
  margin-top: 48rpx;
}
