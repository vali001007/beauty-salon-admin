.project-card {
  position: relative;
  overflow: hidden;
  border: 2rpx solid #ead6ef;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(154, 92, 183, 0.08);
}

.project-card.compact {
  display: flex;
  min-height: 220rpx;
  padding: 28rpx;
  align-items: center;
}

.project-card.large {
  margin-bottom: 46rpx;
}

.image-wrap {
  position: relative;
  flex: 0 0 160rpx;
}

.project-card.large .image-wrap {
  width: 100%;
  height: 330rpx;
}

.project-image {
  display: flex;
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #efe5f6, #d9b8ea);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  align-items: center;
  justify-content: center;
}

.project-card.large .project-image {
  width: 100%;
  height: 330rpx;
  border-radius: 26rpx 26rpx 0 0;
}

.tag {
  position: absolute;
  top: 0;
  left: 0;
  min-width: 92rpx;
  height: 56rpx;
  border-radius: 0 0 20rpx 0;
  background: linear-gradient(135deg, #af6bd2, #d79ce6);
  color: #fff;
  font-size: 26rpx;
  line-height: 56rpx;
  text-align: center;
}

.project-info {
  flex: 1;
  min-width: 0;
  padding-left: 34rpx;
}

.project-card.large .project-info {
  padding: 34rpx 34rpx 38rpx;
}

.project-name {
  color: #33283f;
  font-size: 34rpx;
  font-weight: 700;
}

.project-desc {
  display: -webkit-box;
  margin-top: 22rpx;
  color: #9d8d9f;
  font-size: 28rpx;
  line-height: 44rpx;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.project-meta {
  display: flex;
  margin-top: 36rpx;
  align-items: center;
  justify-content: space-between;
}

.price {
  color: #d22e86;
  font-size: 44rpx;
  font-weight: 800;
}

.duration {
  min-width: 136rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #a967ce, #d59ce7);
  color: #fff;
  font-size: 26rpx;
  line-height: 54rpx;
  text-align: center;
}
