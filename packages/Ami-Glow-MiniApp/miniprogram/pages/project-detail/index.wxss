.detail-page {
  min-height: 100vh;
  padding: 0 40rpx 170rpx;
  background: #fbf4fb;
}

.hero {
  position: relative;
  overflow: hidden;
  height: 520rpx;
  margin: 0 -40rpx;
  background: #ead6ef;
}

.hero-image,
.hero-placeholder {
  display: flex;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #d7b4ea, #f3d8f4);
  color: #fff;
  font-size: 52rpx;
  font-weight: 800;
  align-items: center;
  justify-content: center;
}

.hero-tag {
  position: absolute;
  top: 28rpx;
  left: 28rpx;
  width: 108rpx;
  height: 64rpx;
  border-radius: 0 18rpx 18rpx 0;
  background: #bd7cd7;
  color: #fff;
  font-size: 30rpx;
  line-height: 64rpx;
  text-align: center;
}

.info-card {
  margin-top: 44rpx;
  padding: 48rpx 40rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.member-label {
  display: inline-block;
  height: 64rpx;
  margin-right: 24rpx;
  padding: 0 28rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #a967ce, #d79ce6);
  color: #fff;
  font-size: 30rpx;
  line-height: 64rpx;
}

.price {
  color: #d22e86;
  font-size: 50rpx;
  font-weight: 800;
}

.share {
  color: #8f7a92;
  font-size: 26rpx;
}

.project-name {
  margin-top: 36rpx;
  color: #33283f;
  font-size: 40rpx;
  font-weight: 700;
}

.project-desc {
  margin-top: 28rpx;
  padding: 26rpx;
  background: #fbf0f8;
  color: #9a6172;
  font-size: 30rpx;
  line-height: 52rpx;
}

.detail-card {
  margin-top: 38rpx;
  padding: 42rpx 40rpx;
}

.promotion-card {
  margin-top: 38rpx;
  padding: 42rpx 40rpx;
}

.promotion-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 24rpx;
  padding: 28rpx;
  border: 2rpx solid #f0d7ea;
  border-radius: 26rpx;
  background: #fff8fd;
}

.promotion-main {
  min-width: 0;
  flex: 1;
}

.promotion-name {
  color: #33283f;
  font-size: 30rpx;
  font-weight: 700;
}

.promotion-desc {
  margin-top: 10rpx;
  color: #a05e76;
  font-size: 26rpx;
  line-height: 40rpx;
}

.claim-button {
  width: 144rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #bd7cd7;
  color: #fff;
  font-size: 26rpx;
  line-height: 64rpx;
}

.claim-button.claimed {
  background: #ead6ef;
  color: #8f5ca7;
}

.promotion-note {
  margin-top: 22rpx;
  color: #8f7a92;
  font-size: 24rpx;
  line-height: 38rpx;
}

.detail-title {
  margin-bottom: 26rpx;
  color: #33283f;
  font-size: 38rpx;
  font-weight: 700;
}

.detail-title::after {
  display: block;
  width: 80rpx;
  height: 4rpx;
  margin-top: 16rpx;
  background: #e9b8b9;
  content: "";
}

.detail-line {
  margin-top: 20rpx;
  color: #6e5b78;
  font-size: 29rpx;
  line-height: 48rpx;
}

.bottom-action {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 8;
  padding: 28rpx 40rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-top: 2rpx solid #f0e6f3;
}
