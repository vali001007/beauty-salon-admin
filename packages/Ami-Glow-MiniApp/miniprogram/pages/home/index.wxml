<view class="page">
  <view class="store-row">
    <view class="store-name">⌖ {{home.store.name || '请选择门店'}}</view>
    <button class="scan" bindtap="openScan">⌗</button>
  </view>

  <swiper class="banner" indicator-dots autoplay circular interval="4200">
    <swiper-item wx:for="{{home.banners}}" wx:key="id">
      <view class="banner-card" data-banner="{{item}}" bindtap="openBanner">
        <image wx:if="{{item.image}}" class="banner-image" src="{{item.image}}" mode="aspectFill" />
        <view wx:else class="banner-placeholder">
          <text>{{item.title}}</text>
          <text class="banner-subtitle">{{item.subtitle || 'Ami Glow'}}</text>
        </view>
        <view wx:if="{{item.tag}}" class="banner-tag">{{item.tag}}</view>
      </view>
    </swiper-item>
  </swiper>

  <view class="section-title">推荐服务</view>
  <view class="project-list">
    <project-card wx:for="{{home.recommendedProjects}}" wx:key="id" project="{{item}}" layout="compact" />
  </view>

  <view wx:if="{{!loading && (!home.recommendedProjects || !home.recommendedProjects.length)}}" class="empty card">
    暂无推荐项目
  </view>
</view>

<view class="tabbar">
  <view class="tab active">⌂<text>首页</text></view>
  <view class="tab" bindtap="goBooking">▣<text>预约</text></view>
  <view class="tab" bindtap="goTools">▣<text>工具</text></view>
  <view class="tab" bindtap="goMine">♙<text>我的</text></view>
</view>
