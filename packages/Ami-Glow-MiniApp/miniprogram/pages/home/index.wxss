.store-row {
  display: flex;
  margin-bottom: 26rpx;
  align-items: center;
  justify-content: space-between;
}

.store-name {
  max-width: 560rpx;
  color: #6c536f;
  font-size: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scan {
  width: 60rpx;
  height: 60rpx;
  color: #3a2e48;
  font-size: 42rpx;
  line-height: 60rpx;
}

.banner {
  height: 470rpx;
}

.banner-card {
  position: relative;
  height: 450rpx;
  overflow: hidden;
  border-radius: 26rpx;
  background: #ead6ef;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-placeholder {
  display: flex;
  height: 100%;
  padding: 52rpx;
  background: linear-gradient(135deg, #d7b4ea, #f3d8f4);
  color: #fff;
  font-size: 42rpx;
  font-weight: 800;
  flex-direction: column;
  justify-content: center;
}

.banner-subtitle {
  margin-top: 22rpx;
  font-size: 28rpx;
}

.banner-tag {
  position: absolute;
  top: 26rpx;
  left: 0;
  min-width: 104rpx;
  height: 60rpx;
  border-radius: 0 18rpx 18rpx 0;
  background: #bd7cd7;
  color: #fff;
  font-size: 28rpx;
  line-height: 60rpx;
  text-align: center;
}

.project-list project-card {
  display: block;
  margin-bottom: 36rpx;
}

.empty {
  padding: 56rpx;
  color: #9f93a5;
  text-align: center;
}

.tabbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: flex;
  height: 126rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.96);
  border-top: 2rpx solid #f0e6f3;
}

.tab {
  flex: 1;
  display: flex;
  color: #77717c;
  font-size: 44rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.tab text {
  margin-top: 4rpx;
  font-size: 24rpx;
}

.tab.active {
  color: #8d21bf;
}
