.guide {
  padding: 36rpx;
}

.guide-title {
  margin-bottom: 20rpx;
  color: #33283f;
  font-size: 34rpx;
  font-weight: 700;
}

.guide-item {
  margin-top: 14rpx;
  color: #6e5b78;
  font-size: 28rpx;
  line-height: 44rpx;
}

.preview {
  display: flex;
  height: 520rpx;
  margin-top: 34rpx;
  color: #9f93a5;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.preview image {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
}

.camera {
  margin-bottom: 18rpx;
  color: #a967ce;
  font-size: 80rpx;
}

.agree {
  display: flex;
  margin: 34rpx 0;
  color: #6e5b78;
  font-size: 26rpx;
  line-height: 42rpx;
}

.checkbox {
  flex: 0 0 36rpx;
  width: 36rpx;
  height: 36rpx;
  margin-right: 14rpx;
  border: 2rpx solid #b56ad4;
  border-radius: 8rpx;
  color: #b56ad4;
  line-height: 34rpx;
  text-align: center;
}
