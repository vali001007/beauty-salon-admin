<view class="page">
  <view wx:for="{{cards}}" wx:key="id" class="card-item card">
    <view class="name">{{item.cardName}}</view>
    <view class="count">剩余 {{item.remainingTimes}} / {{item.totalTimes}} 次</view>
    <view class="line">有效期至：{{item.expiryDate}}</view>
    <view class="line">适用项目：{{item.applicableProjects.join('、') || '到店咨询'}}</view>
  </view>
  <view wx:if="{{!cards.length}}" class="empty card">暂无可用次卡</view>
</view>
