.member-card {
  padding: 50rpx 42rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #b36bd4, #d9a2e9);
  color: #fff;
  box-shadow: 0 16rpx 30rpx rgba(171, 103, 205, 0.24);
}
.level {
  font-size: 34rpx;
  font-weight: 700;
}
.balance {
  margin-top: 28rpx;
  font-size: 72rpx;
  font-weight: 900;
}
.gift {
  margin-top: 12rpx;
  font-size: 28rpx;
}
.benefits {
  margin-top: 34rpx;
  padding: 36rpx;
}
.title {
  color: #33283f;
  font-size: 34rpx;
  font-weight: 700;
}
.benefit {
  margin-top: 20rpx;
  color: #6e5b78;
  font-size: 29rpx;
}
