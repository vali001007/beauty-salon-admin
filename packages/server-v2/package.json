{
  "name": "ami-core-api",
  "version": "1.0.0",
  "description": "Ami Core API - NestJS Backend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:mvp": "ts-node --esm prisma/seed-mvp.ts",
    "db:seed:mvp:dry-run": "ts-node --esm prisma/seed-mvp.ts --dry-run",
    "db:seed:promotion-assets": "ts-node --esm prisma/seed-promotion-assets-runner.ts --apply --yes",
    "db:seed:promotion-assets:dry-run": "ts-node --esm prisma/seed-promotion-assets-runner.ts",
    "db:seed:promotion-assets:verify": "ts-node --esm prisma/seed-promotion-assets-runner.ts --verify",
    "db:seed:demo-full": "ts-node --esm prisma/seed-demo-full-store.ts --apply --yes",
    "db:seed:demo-full:dry-run": "ts-node --esm prisma/seed-demo-full-store.ts --dry-run",
    "db:seed:industry-mvp": "ts-node --esm prisma/seed-industry-mvp.ts --apply --yes",
    "db:seed:industry-mvp:dry-run": "ts-node --esm prisma/seed-industry-mvp.ts --dry-run",
    "db:seed:industry-mvp:verify": "ts-node --esm prisma/seed-industry-mvp.ts --verify-only",
    "industry-bom:sync": "ts-node --esm prisma/sync-industry-bom-to-core.ts --apply --yes",
    "industry-bom:sync:dry-run": "ts-node --esm prisma/sync-industry-bom-to-core.ts --dry-run",
    "industry-bom:sync:verify": "ts-node --esm prisma/sync-industry-bom-to-core.ts --verify-only",
    "supply-platform:mvp-flow": "ts-node --esm prisma/supply-platform-mvp-flow.ts --apply --yes",
    "supply-platform:mvp-flow:dry-run": "ts-node --esm prisma/supply-platform-mvp-flow.ts --dry-run",
    "supply-platform:mvp-flow:verify": "ts-node --esm prisma/supply-platform-mvp-flow.ts --verify",
    "db:retain:ami-demo": "ts-node --esm prisma/retain-ami-full-demo-store.ts --apply --yes --confirm-retain-store-name=\"Ami 全量演示门店\"",
    "db:retain:ami-demo:dry-run": "ts-node --esm prisma/retain-ami-full-demo-store.ts --dry-run",
    "operation-profit:audit": "ts-node --esm prisma/operation-profit-audit.ts",
    "operation-profit:assignee-audit": "ts-node --esm prisma/operation-profit-assignee-audit.ts",
    "operation-profit:assignee-backfill": "ts-node --esm prisma/operation-profit-assignee-backfill.ts",
    "operation-profit:backfill": "ts-node --esm prisma/operation-profit-backfill.ts",
    "operation-profit:beautician-user-audit": "ts-node --esm prisma/operation-profit-beautician-user-audit.ts",
    "operation-profit:beautician-user-backfill": "ts-node --esm prisma/operation-profit-beautician-user-backfill.ts",
    "operation-profit:bom-audit": "ts-node --esm prisma/operation-profit-bom-audit.ts",
    "operation-profit:confirmation-audit": "ts-node --esm prisma/operation-profit-confirmation-audit.ts",
    "operation-profit:confirmation-template": "ts-node --esm prisma/operation-profit-confirmation-template.ts",
    "operation-profit:confirmation-workbook": "ts-node --esm prisma/operation-profit-confirmation-workbook.ts",
    "operation-profit:confirmed-dry-run": "ts-node --esm prisma/operation-profit-confirmed-dry-run.ts",
    "operation-profit:cost-seed": "ts-node --esm prisma/operation-profit-cost-seed.ts",
    "operation-profit:project-master-backfill": "ts-node --esm prisma/operation-profit-project-master-backfill.ts",
    "operation-profit:readiness": "ts-node --esm prisma/operation-profit-readiness.ts",
    "operation-profit:sample-reconcile": "ts-node --esm prisma/operation-profit-sample-reconcile.ts",
    "operation-profit:scripts:typecheck": "tsc -p tsconfig.operation-profit-scripts.json --noEmit",
    "operation-profit:staff-user-backfill": "ts-node --esm prisma/operation-profit-staff-user-backfill.ts",
    "operation-profit:staff-user-template": "ts-node --esm prisma/operation-profit-staff-user-template.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "ts-node --esm prisma/seed.ts"
  }
}
