PORT=18080
DATABASE_URL=postgresql://ami_core:ami_core@localhost:5432/ami_core
# Shared/session-mode databases have a small global client limit. Local development
# defaults to two reusable connections; production defaults to five unless overridden.
DATABASE_POOL_MAX=2
DATABASE_IDLE_TIMEOUT_MS=10000
DATABASE_CONNECTION_TIMEOUT_MS=10000
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret-also-long-random
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Cache only verified active principals; 0 disables it, maximum 30000 ms.
JWT_PRINCIPAL_CACHE_TTL_MS=5000

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5175
REQUEST_BODY_LIMIT=12mb
MARKETING_RECOMMENDATION_IMAGE_URL=https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=400
MARKETING_RECOMMENDATION_INSTANCE_WRITE=true
MARKETING_RECOMMENDATION_INSTANCE_READ=false
MARKETING_RECOMMENDATION_ADOPTION_V2=false
# Local development keeps recurring marketing jobs off so interactive API requests
# are not starved by the shared session-mode database pool. Production defaults on.
MARKETING_SCHEDULER_ENABLED=false
MARKETING_DELIVERY_JOB_ENGINE=false
# Local development disables recurring terminal automation scans; production defaults on.
TERMINAL_AUTOMATION_SCHEDULER=disabled
MARKETING_EFFECT_FACT_WRITE=false
MARKETING_EFFECT_FACT_READ=false
# Empty means no stores; use comma-separated IDs or explicit * for all stores.
MARKETING_ROLLOUT_STORE_IDS=
ADMIN_DEFAULT_PASSWORD=11111111
DEMO_USER_DEFAULT_PASSWORD=11111111

LLM_PROVIDER=openai_responses
LLM_API_KEY=
# Optional: resolve the key from another environment variable instead of duplicating it here.
LLM_API_KEY_ENV=
LLM_BASE_URL=https://your-openai-responses-relay.example/v1
LLM_CHAT_PATH=/responses
LLM_MODEL=gpt-5.6-terra
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_TIMEOUT_MS=30000
LLM_STREAM=false
LLM_THINKING=disabled
# Empty disables extra Responses reasoning latency; Brain performs its own validation and planning.
LLM_REASONING_EFFORT=
LLM_DAILY_BUDGET=50
# Brain uses JSON Object plus local Ajv validation because its Draft-07 schema is richer than relay strict schemas.
LLM_STRUCTURED_OUTPUT_MODE=json_object
LLM_STRUCTURED_MAX_TOTAL_TOKENS=8192

# Optional fallback provider
LLM_FALLBACK_PROVIDER=kimi
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_API_KEY_ENV=
LLM_FALLBACK_BASE_URL=https://api.moonshot.ai/v1
LLM_FALLBACK_CHAT_PATH=/chat/completions
LLM_FALLBACK_MODEL=kimi-k2.7-code-highspeed
LLM_FALLBACK_TIMEOUT_MS=30000
LLM_FALLBACK_STRUCTURED_OUTPUT_MODE=auto
LLM_FALLBACK_STRUCTURED_MAX_TOTAL_TOKENS=8192

# Ami Brain local-safe runtime defaults
BRAIN_COGNITION_MODE=rules
BRAIN_PLANNER_MODE=rules
BRAIN_MODEL_SHADOW_PERCENT=0
BRAIN_MODEL_CANARY_PERCENT=0
BRAIN_MODEL_MIN_CONFIDENCE=0.85
BRAIN_CAPABILITY_TOP_K=8
BRAIN_CAPABILITY_MIN_CONFIDENCE=0.3
BRAIN_MAX_PLAN_NODES=8
BRAIN_MAX_REPLANS=2
BRAIN_TOTAL_TIMEOUT_MS=20000
BRAIN_MODEL_TIMEOUT_MS=15000
BRAIN_SINGLE_TOOL_FAST_PATH=true
BRAIN_ALLOW_CANDIDATE_INSPECTION_GUARDS=false
BRAIN_GOVERNANCE_SYSTEM_USER_ID=
BRAIN_SEMANTIC_EVIDENCE_WORKER_ENABLED=false
BRAIN_SEMANTIC_EVIDENCE_BATCH_SIZE=100
BRAIN_SEMANTIC_AUTOMATION_USER_ID=
BRAIN_CAPABILITY_REGENERATION_WORKER_ENABLED=false
BRAIN_CAPABILITY_WORKSPACE_ROOT=

# Agent V2 治理、灰度与自动发布
AGENT_V2_DEPLOY_HOOK_URL=
AGENT_V2_AUTO_PUBLISH_DEPLOY_TOKEN=
AGENT_V2_PRODUCTION_BACKEND_ENV_CONFIRMED=false
# 当前策略：GitHub main 分支提交触发 auto-publish hook；后端进程不做定时自动发布。
AGENT_V2_AUTO_PUBLISH_CRON=false
AGENT_V2_AUTO_PUBLISH_BASE_REF=origin/main
AGENT_V2_GRAY_MODE=kg_llm_preferred
AGENT_V2_GRAY_RULES=
AGENT_LLM_TASK_COMPILER_ENABLED=true
AGENT_V2_LEGACY_RETIREMENT_CONFIRMED=false
# 兼容旧意图引擎开关；本地默认 kg_llm_preferred，仍保留 legacy 回退。
AGENT_INTENT_ENGINE=kg_llm
# true 时开启本地影子对比，不改变正式返回链路。
AGENT_INTENT_SHADOW_COMPARE=false

# Agent V2 受控 Text-to-SQL
# 本地样例默认开启 dry-run / guard inspect，便于治理台闭环；生产需显式配置，且只在 strict readiness 通过后打开 execute。
AGENT_V2_TEXT_TO_SQL_ENABLED=true
# 默认仅管理员/治理角色可用；生产不建议改为 false，除非已完成只读库、脱敏和审计验收。
AGENT_V2_TEXT_TO_SQL_ADMIN_ONLY=true
AGENT_V2_TEXT_TO_SQL_MAX_LIMIT=100
AGENT_V2_TEXT_TO_SQL_TIMEOUT_MS=5000
AGENT_V2_TEXT_TO_SQL_MAX_RANGE_DAYS=365
AGENT_V2_TEXT_TO_SQL_MAX_ESTIMATED_COST=100000
# 预留给灰度/生产 execute：必须配置独立只读库连接；留空时只允许 dry-run / guard inspect，不访问主业务库。
# 不允许把 DATABASE_URL 直接填到这里。
AGENT_V2_TEXT_TO_SQL_READONLY_DATABASE_URL=

# Face++ 皮肤分析-高阶版，仅后端配置，前端不要保存 Key
FACEPP_API_KEY=
FACEPP_API_SECRET=
FACEPP_SKIN_ANALYZE_URL=https://api-cn.faceplusplus.com/facepp/v1/skinanalyze
FACEPP_SKIN_ANALYZE_TIMEOUT_MS=30000
# true: Face++ 不可用时返回演示级兜底结果；false: 直接返回错误
FACEPP_SKIN_ANALYZE_FALLBACK=true
