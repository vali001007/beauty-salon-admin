{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist-agent-eval-scripts",
    "declaration": false,
    "sourceMap": false,
    "incremental": false,
    "noEmit": true
  },
  "include": [
    "prisma/agent-all-version-eval.ts",
    "prisma/agent-eval-*.ts",
    "prisma/agent-knowledge-*.ts",
    "prisma/agent-v2-*.ts",
    "prisma/ami-brain-data-quality-inspection.ts",
    "prisma/ami-brain-pending-migration-preflight.ts",
    "prisma/ami-brain-capability-archive-superseded.ts",
    "prisma/ami-brain-full-domain-eval.ts",
    "prisma/ami-brain-full-domain-eval-suite.ts",
    "prisma/generate-schema-graph.ts",
    "src/**/*"
  ],
  "exclude": ["node_modules", "dist", "dist-agent-eval-scripts", "src/**/*.spec.ts", "test/**/*"]
}
