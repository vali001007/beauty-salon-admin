model CommissionRule {
  id              Int      @id @default(autoincrement())
  storeId         Int
  name            String
  type            String
  targetType      String   @default("all")
  targetId        Int?
  levelId         Int?
  userId          Int?
  rate            Decimal
  fixedAmount     Decimal?
  calcBase        String   @default("total")
