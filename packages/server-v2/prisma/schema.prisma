  staffUser  User?      @relation("CommissionSettlementStaffUser", fields: [staffUserId], references: [id], onDelete: SetNull)
  beautician Beautician? @relation(fields: [beauticianId], references: [id], onDelete: SetNull)

  @@unique([storeId, staffUserId, settleMonth])
  @@index([storeId, settleMonth])
  @@index([staffUserId])
  @@index([beauticianId])
}

model CashierShift {
