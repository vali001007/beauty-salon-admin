  @@index([customerCardId, verifiedAt])
  @@index([cardId])
  @@index([projectId, verifiedAt])
  @@index([storeId, verifiedAt])
  @@index([sourceOrderId])
  @@index([sourceOrderItemId])
  @@index([operatorId])
  @@index([beauticianId])
  @@index([deviceId])
  @@index([verifiedAt])
