// ─── Finance & Commission ───────────────────────────────────────────────────

model CommissionRule {
  id              Int      @id @default(autoincrement())
  storeId         Int
  name            String
  type            String
  targetType      String   @default("all")
  targetId        Int?
  levelId         Int?
  userId          Int?
  rate            Decimal
  fixedAmount     Decimal?
  calcBase        String   @default("total")
  isDesignated    Boolean  @default(false)
  designatedBonus Decimal?
  minThreshold    Decimal?
  status          String   @default("active")
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store              @relation(fields: [storeId], references: [id])
  level   BeauticianLevel?   @relation(fields: [levelId], references: [id])
  user    User?              @relation("CommissionRuleUser", fields: [userId], references: [id], onDelete: SetNull)
  records CommissionRecord[]

  @@index([storeId, type, status])
  @@index([levelId])
  @@index([userId])
}

model CommissionRecord {
  id           Int       @id @default(autoincrement())
  storeId      Int
  staffUserId  Int?
  beauticianId Int?
  orderId      Int?
  orderItemId  Int?
  sourceType   String?
  sourceId     Int?
  cardUsageRecordId Int?
  ruleId       Int?
  type         String
  sourceAmount Decimal
  rate         Decimal
  amount       Decimal
  status       String    @default("pending")
  settleMonth  String?
  confirmedAt  DateTime?
  settledAt    DateTime?
  remark       String?
  createdAt    DateTime  @default(now())

  store      Store           @relation(fields: [storeId], references: [id])
  staffUser  User?           @relation("CommissionRecordStaffUser", fields: [staffUserId], references: [id], onDelete: SetNull)
  beautician Beautician?     @relation(fields: [beauticianId], references: [id], onDelete: SetNull)
  order      ProductOrder?   @relation(fields: [orderId], references: [id])
  orderItem  OrderItem?      @relation(fields: [orderItemId], references: [id])
  cardUsageRecord CardUsageRecord? @relation(fields: [cardUsageRecordId], references: [id], onDelete: SetNull)
  rule       CommissionRule? @relation(fields: [ruleId], references: [id])

  @@index([beauticianId, settleMonth])
  @@index([staffUserId, settleMonth])
  @@index([storeId, status])
  @@index([orderId])
  @@index([orderItemId])
  @@index([sourceType, sourceId])
  @@index([cardUsageRecordId])
  @@index([ruleId])
}

model CommissionSettlement {
  id             Int       @id @default(autoincrement())
