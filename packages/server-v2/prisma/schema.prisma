generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum EntityStatus {
  active
  disabled
  archived
}

enum TerminalDeviceStatus {
  online
  offline
  disabled
  pending_unbind
}

enum ServiceTaskStatus {
  pending
  in_progress
  completed
  cancelled
  no_show
}

enum MarketingStrategyStatus {
  draft
  enabled
  paused
  archived
}

// ─── Auth & Access ───────────────────────────────────────────────────────────

model Store {
  id        Int       @id @default(autoincrement())
  name      String
  city      String?
  address   String?
  phone     String?
  status    String    @default("active")
  shiftRequired Boolean @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users                    UserStore[]
  customers                Customer[]
  predictionRuns           PredictionRun[]
  predictionSnapshots      CustomerPredictionSnapshot[]
  products                 Product[]
  projects                 Project[]
  beauticians              Beautician[]
  schedules                Schedule[]
  reservations             Reservation[]
  productOrders            ProductOrder[]
  transferOrdersFrom       TransferOrder[]              @relation("TransferFromStore")
  transferOrdersTo         TransferOrder[]              @relation("TransferToStore")
  stockMovements           StockMovement[]
  terminalDevices          TerminalDevice[]
  terminalConversations    TerminalConversation[]
  serviceTasks             ServiceTask[]
  recommendationEvents     RecommendationEvent[]
  balanceAccounts          CustomerBalanceAccount[]
  balanceTransactions      CustomerBalanceTransaction[]
  promotions               Promotion[]
  printJobs                PrintJob[]
  aiAuditLogs              AiAuditLog[]
  commissionRules          CommissionRule[]
  commissionRecords        CommissionRecord[]
  commissionSettlements    CommissionSettlement[]
  cashierShifts            CashierShift[]
  dailySettlements         DailySettlement[]
  amiPerformanceRecords    AmiPerformanceRecord[]
  marketingRuleTemplates   MarketingRuleTemplate[]
  amiMonthlyBills          AmiMonthlyBill[]
  suppliers                Supplier[]
  supplierOrders           SupplierOrder[]
  procurementOrders        ProcurementOrder[]
  schedulingRuleConfigs    SchedulingRuleConfig[]
  beauticianAvailabilities BeauticianAvailability[]
  beauticianTimeOffs       BeauticianTimeOff[]
  smartSchedulingRuns      SmartSchedulingRun[]
  storeResources           StoreResource[]
  resourceBookings         ResourceBooking[]
  customerAppIdentities    CustomerAppIdentity[]
  customerAppEvents        CustomerAppEvent[]
  amiGlowDisplayConfigs    AmiGlowDisplayConfig[]
  terminalFollowUpTasks    TerminalFollowUpTask[]
  operatingCosts           OperatingCost[]
  cardUsageRecords         CardUsageRecord[]
  cards                    Card[]

  @@index([status])
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String
  name         String
  phone        String?
  email        String?
  avatar       String?
  supplySupplierId Int?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  roles               UserRole[]
  stores              UserStore[]
  aiAuditLogs         AiAuditLog[]
  refreshTokens       RefreshToken[]
  stockMovements      StockMovement[]
  smartSchedulingRuns SmartSchedulingRun[] @relation("SmartSchedulingRunCreatedBy")
  handledBalanceTransactions CustomerBalanceTransaction[] @relation("BalanceTransactionOperator")
  handledCustomerCards CustomerCard[] @relation("CustomerCardOperator")
  handledCardUsageRecords CardUsageRecord[] @relation("CardUsageOperator")
  cashierShifts       CashierShift[]
  terminalConversations TerminalConversation[]
  beauticianProfiles Beautician[]
  assignedFollowUpTasks TerminalFollowUpTask[] @relation("FollowUpAssignedUser")
  createdFollowUpTasks TerminalFollowUpTask[] @relation("FollowUpCreatedBy")
  completedFollowUpTasks TerminalFollowUpTask[] @relation("FollowUpCompletedBy")
  createdOperatingCosts  OperatingCost[]        @relation("OperatingCostCreatedBy")
  commissionRules        CommissionRule[]        @relation("CommissionRuleUser")
  commissionRecords      CommissionRecord[]      @relation("CommissionRecordStaffUser")
  commissionSettlements  CommissionSettlement[]  @relation("CommissionSettlementStaffUser")
  supplySupplier         SupplySupplier?         @relation(fields: [supplySupplierId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([phone])
  @@index([supplySupplierId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id             Int      @id @default(autoincrement())
  key            String   @unique
  name           String
  description    String?
  isSystem       Boolean  @default(false)
  permissions    String[]
  platformScopes Json?
  dataScopes     Json?
  fieldScopes    Json?
  approvalScopes Json?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users UserRole[]
}

model UserRole {
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model UserStore {
  userId  Int
  storeId Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id            Int       @id @default(autoincrement())
  storeId       Int
  name          String
  phone         String?
  email         String?
  wechat        String?
  landline      String?
  gender        String?
  maritalStatus String?
  birthday      DateTime?
  age           Int?
  height        Decimal?
  weight        Decimal?
  occupation    String?
  workplace     String?
  address       String?
  hasAllergy    String?
  hasSurgery    String?
  skinCondition String?
  memberLevel   String    @default("无")
  source        String?
  totalSpent    Decimal   @default(0)
  visitCount    Int       @default(0)
  lastVisitDate DateTime?
  skinType      String?
  tags          String[]
  remark        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  store                 Store                        @relation(fields: [storeId], references: [id])
  healthProfile         CustomerHealthProfile?
  consumptionRecords    ConsumptionRecord[]
  customerCards         CustomerCard[]
  productOrders         ProductOrder[]
  reservations          Reservation[]
  serviceTasks          ServiceTask[]
  cardUsageRecords      CardUsageRecord[]
  skinTests             SkinTest[]
  predictionSnapshots   CustomerPredictionSnapshot[]
  amiPerformanceRecords AmiPerformanceRecord[]
  marketingTouches      MarketingAutomationTouch[]
  marketingAttributions MarketingAttribution[]
  pageAttributions      MarketingPageAttribution[]
  recommendationEvents  RecommendationEvent[]
  balanceAccounts       CustomerBalanceAccount[]
  balanceTransactions   CustomerBalanceTransaction[]
  customerAppIdentities CustomerAppIdentity[]
  terminalFollowUpTasks TerminalFollowUpTask[]
  customerAppEvents     CustomerAppEvent[]

  @@index([storeId])
  @@index([phone])
  @@index([memberLevel])
  @@index([name])
}

model CustomerHealthProfile {
  id              Int      @id @default(autoincrement())
  customerId      Int      @unique
  skinType        String
  skinStatus      String?
  mainProblems    String?
  allergyHistory  String?
  goals           String?
  recommendedCare String?
  instrument      String?
  lastCheck       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model ConsumptionRecord {
  id             Int      @id @default(autoincrement())
  customerId     Int
  consumeType    String
  consumeContent String
  payMethod      String?
  amount         Decimal  @default(0)
  campaign       String?
  consumeTime    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([consumeTime])
}

// ─── Products & Inventory ────────────────────────────────────────────────────

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id                 Int       @id @default(autoincrement())
  storeId            Int
  categoryId         Int?
  sku                String    @unique
  name               String
  brand              String?
  spec               String?
  unit               String?
  costPrice          Decimal   @default(0)
  retailPrice        Decimal   @default(0)
  shelfLife          Int?
  supplier           String?
  minPurchaseQty     Int       @default(0)
  image              String?
  status             String    @default("active")
  salePrice          Decimal?
  discountRate       Decimal?
  discountLabel      String?
  salesDescription   String?
  miniappStatus      String    @default("unpublished")
  miniappPublishedAt DateTime?
  currentStock       Decimal   @default(0)
  safetyStock        Decimal   @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  store          Store            @relation(fields: [storeId], references: [id])
  category       Category?        @relation(fields: [categoryId], references: [id])
  batches        StockBatch[]
  bomItems       ProjectBomItem[]
  stockMovements StockMovement[]
  suppliers      ProductSupplier[]
  supplierItems  SupplierOrderItem[]
  supplyMappings SupplyCatalogMapping[]
  procurementItems ProcurementOrderItem[]

  @@index([storeId])
  @@index([status])
  @@index([miniappStatus])
  @@index([categoryId])
}

model StockBatch {
  id             Int       @id @default(autoincrement())
  productId      Int
  batchNo        String
  stock          Decimal   @default(0)
  productionDate DateTime?
  expiryDate     DateTime?
  createdAt      DateTime  @default(now())

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@index([productId])
  @@index([expiryDate])
}

model Supplier {
  id           Int       @id @default(autoincrement())
  storeId      Int?
  name         String
  contactName  String?
  phone        String?
  email        String?
  address      String?
  category     String?
  rebateRate   Decimal?
  paymentTerms String?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  store       Store?               @relation(fields: [storeId], references: [id], onDelete: SetNull)
  products    ProductSupplier[]
  orders      SupplierOrder[]
  settlements SupplierSettlement[]

  @@index([storeId])
  @@index([status])
  @@index([category])
  @@index([name])
}

model ProductSupplier {
  id          Int      @id @default(autoincrement())
  productId   Int
  supplierId  Int
  supplyPrice Decimal  @default(0)
  moq         Int?
  leadDays    Int?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@index([supplierId])
  @@index([productId, isPrimary])
}

model SupplierOrder {
  id           Int       @id @default(autoincrement())
  orderNo      String    @unique
  supplierId   Int
  storeId      Int
  totalAmount  Decimal   @default(0)
  platformFee  Decimal   @default(0)
  rebateAmount Decimal   @default(0)
  netAmount    Decimal   @default(0)
  status       String    @default("pending")
  orderedAt    DateTime  @default(now())
  receivedAt   DateTime?
  settledAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  store    Store               @relation(fields: [storeId], references: [id])
  items    SupplierOrderItem[]

  @@index([supplierId, status])
  @@index([storeId])
  @@index([status])
  @@index([orderedAt])
}

model SupplierOrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  productId   Int
  quantity    Int
  unitPrice   Decimal @default(0)
  subtotal    Decimal @default(0)
  receivedQty Int?

  order   SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model SupplierSettlement {
  id             Int       @id @default(autoincrement())
  supplierId     Int
  settleMonth    String
  orderCount     Int       @default(0)
  totalAmount    Decimal   @default(0)
  rebateAmount   Decimal   @default(0)
  platformFee    Decimal   @default(0)
  netPayable     Decimal   @default(0)
  status         String    @default("draft")
  confirmedAt    DateTime?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([supplierId, settleMonth])
  @@index([supplierId])
  @@index([settleMonth])
  @@index([status])
}

model PurchaseOrder {
  id          Int      @id @default(autoincrement())
  orderNo     String   @unique
  supplier    String?
  totalAmount Decimal  @default(0)
  status      String   @default("pending")
  items       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model TransferOrder {
  id           Int      @id @default(autoincrement())
  orderNo      String   @unique
  fromStoreId  Int
  toStoreId    Int
  productCount Int      @default(0)
  status       String   @default("pending")
  items        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fromStore Store @relation("TransferFromStore", fields: [fromStoreId], references: [id])
  toStore   Store @relation("TransferToStore", fields: [toStoreId], references: [id])

  @@index([status])
}

model StockMovement {
  id           Int      @id @default(autoincrement())
  storeId      Int
  productId    Int
  batchId      Int?
  movementNo   String   @unique
  movementType String
  quantity     Decimal
  beforeStock  Decimal?
  afterStock   Decimal?
  unit         String?
  sourceType   String?
  sourceId     Int?
  sourceNo     String?
  remark       String?
  operatorId   Int?
  occurredAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  store    Store       @relation(fields: [storeId], references: [id])
  product  Product     @relation(fields: [productId], references: [id])
  batch    StockBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  operator User?       @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([storeId, productId, occurredAt])
  @@index([movementType])
  @@index([sourceType, sourceId])
  @@index([batchId])
  @@index([operatorId])
}

// ─── Projects & Services ─────────────────────────────────────────────────────

model ProjectType {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  status      String    @default("active")
  projects    Project[]
}

model Project {
  id          Int       @id @default(autoincrement())
  storeId     Int
  typeId      Int?
  name        String
  description String?
  price       Decimal   @default(0)
  duration    Int       @default(60)
  image       String?
  recommend   Boolean   @default(false)
  online      Boolean   @default(true)
  home        Boolean   @default(false)
  sort        Int       @default(0)
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  store            Store                    @relation(fields: [storeId], references: [id])
  type             ProjectType?             @relation(fields: [typeId], references: [id])
  bomItems         ProjectBomItem[]
  serviceTasks     ServiceTask[]
  reservations     Reservation[]
  beauticianSkills BeauticianProjectSkill[]
  cardUsageRecords CardUsageRecord[]

  @@index([storeId])
  @@index([status])
}

model ProjectBomItem {
  id          Int     @id @default(autoincrement())
  projectId   Int
  productId   Int
  standardQty Decimal @default(0)
  unit        String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── Industry Data Platform ─────────────────────────────────────────────────

model IndustryDataSource {
  id              Int       @id @default(autoincrement())
  name            String
  sourceType      String    @default("manual")
  licenseType     String?
  confidenceLevel String    @default("medium")
  applicableScope String?
  ownerName       String?
  sourceUrl       String?
  notes           String?
  status          String    @default("draft")
  lastVerifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  evidences        IndustryEvidence[]
  serviceTemplates IndustryServiceTemplate[]
  bomTemplates     IndustryProjectBomTemplate[]
  knowledgeItems   IndustryKnowledgeItem[]

  @@index([sourceType])
  @@index([status])
  @@index([confidenceLevel])
}

model IndustryEvidence {
  id          Int      @id @default(autoincrement())
  sourceId    Int
  title       String
  evidenceType String  @default("link")
  url         String?
  filePath    String?
  notes       String?
  createdAt   DateTime @default(now())

  source IndustryDataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([evidenceType])
}

model IndustryServiceTemplate {
  id                     Int       @id @default(autoincrement())
  code                   String    @unique
  name                   String
  aliases                Json?
  category               String
  subCategory            String?
  targetStoreTypes       Json?
  recommendedDurationMin Int?
  recommendedDurationMax Int?
  referencePriceMin      Decimal?
  referencePriceMax      Decimal?
  targetCustomers        Json?
  contraindications      Json?
  recommendedFrequency   String?
  sellingPoints          Json?
  bomUnavailableReason   String?
  status                 String    @default("draft")
  version                Int       @default(1)
  sourceId               Int?
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  source         IndustryDataSource?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  bomTemplates   IndustryProjectBomTemplate[]
  adoptionRecords IndustryAdoptionRecord[]

  @@index([category])
  @@index([status])
  @@index([sourceId])
  @@index([name])
}

model IndustryProductTemplate {
  id                          Int       @id @default(autoincrement())
  standardProductCode          String    @unique
  name                        String
  aliases                     Json?
  category                    String
  subCategory                 String?
  productType                 String
  recommendedSpec             String?
  unit                        String?
  packageUnit                 String?
  referenceCostMin            Decimal?
  referenceCostMax            Decimal?
  referenceRetailPriceMin     Decimal?
  referenceRetailPriceMax     Decimal?
  applicableServiceCategories Json?
  supplyCategoryCode          String?
  preferredSpecKey            String?
  externalMappingKey          String?
  futureSupplyMappingStatus   String    @default("not_connected")
  status                      String    @default("draft")
  version                     Int       @default(1)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  deletedAt                   DateTime?

  bomItems       IndustryProjectBomItemTemplate[]
  supplyMappings SupplyCatalogMapping[]

  @@index([category])
  @@index([productType])
  @@index([status])
  @@index([futureSupplyMappingStatus])
  @@index([name])
}

// ─── Supply Platform ────────────────────────────────────────────────────────

model SupplySupplier {
  id                  Int       @id @default(autoincrement())
  name                String
  companyName         String?
  contactName         String?
  phone               String?
  email               String?
  address             String?
  serviceRegions      Json?
  categories          Json?
  qualificationStatus String    @default("pending")
  settlementMode      String    @default("monthly")
  paymentTerms        String?
  rebateRate          Decimal?
  platformFeeRate     Decimal?
  status              String    @default("pending")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  qualifications SupplierQualification[]
  users          User[]
  skus           SupplySku[]
  quotes         SupplyQuote[]
  orders         ProcurementOrder[]
  shipments      SupplierShipment[]
  settlements    SupplySettlement[]

  @@index([status])
  @@index([qualificationStatus])
  @@index([name])
}

model SupplierQualification {
  id           Int       @id @default(autoincrement())
  supplierId   Int
  type         String
  fileUrl      String
  fileName     String?
  status       String    @default("pending")
  reviewedBy   Int?
  reviewedAt   DateTime?
  rejectReason String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier SupplySupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([status])
  @@index([type])
}

model SupplySku {
  id                 Int       @id @default(autoincrement())
  supplierId         Int
  categoryId         Int?
  name               String
  brand              String?
  spec               String?
  unit               String?
  barcode            String?
  images             Json?
  shelfLife          Int?
  qualificationFiles Json?
  description        String?
  status             String    @default("draft")
  auditStatus        String    @default("draft")
  reviewedBy         Int?
  reviewedAt         DateTime?
  rejectReason       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  supplier      SupplySupplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  quotes        SupplyQuote[]
  mappings      SupplyCatalogMapping[]
  orderItems    ProcurementOrderItem[]
  shipmentItems SupplierShipmentItem[]

  @@index([supplierId])
  @@index([status])
  @@index([auditStatus])
  @@index([name])
  @@index([barcode])
}

model SupplyQuote {
  id             Int       @id @default(autoincrement())
  supplySkuId    Int
  supplierId     Int
  price          Decimal   @default(0)
  taxIncluded    Boolean   @default(true)
  moq            Int       @default(1)
  leadDays       Int?
  stockStatus    String    @default("available")
  availableStock Int?
  regionScope    Json?
  storeScope     Json?
  validFrom      DateTime?
  validTo        DateTime?
  status         String    @default("draft")
  auditStatus    String    @default("draft")
  reviewedBy     Int?
  reviewedAt     DateTime?
  rejectReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  sku        SupplySku             @relation(fields: [supplySkuId], references: [id], onDelete: Cascade)
  supplier   SupplySupplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  orderItems ProcurementOrderItem[]

  @@index([supplySkuId])
  @@index([supplierId])
  @@index([status])
  @@index([auditStatus])
  @@index([validTo])
}

model SupplyCatalogMapping {
  id                        Int      @id @default(autoincrement())
  supplySkuId                Int
  productId                  Int?
  storeId                    Int?
  standardProductTemplateId  Int?
  mappingStatus              String   @default("active")
  isPreferred                Boolean  @default(false)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  supplySku               SupplySku                @relation(fields: [supplySkuId], references: [id], onDelete: Cascade)
  product                 Product?                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  industryProductTemplate IndustryProductTemplate? @relation(fields: [standardProductTemplateId], references: [id], onDelete: SetNull)

  @@index([supplySkuId])
  @@index([productId])
  @@index([storeId])
  @@index([standardProductTemplateId])
  @@index([mappingStatus])
}

model ProcurementOrder {
  id                  Int       @id @default(autoincrement())
  orderNo             String    @unique
  storeId             Int
  supplierId          Int
  status              String    @default("pending_supplier_confirm")
  totalAmount         Decimal   @default(0)
  platformFee         Decimal   @default(0)
  rebateAmount        Decimal   @default(0)
  netAmount           Decimal   @default(0)
  expectedArrivalDate DateTime?
  sourceType          String    @default("manual")
  sourceNo            String?
  createdBy           Int?
  acceptedAt          DateTime?
  rejectedAt          DateTime?
  shippedAt           DateTime?
  receivedAt          DateTime?
  settledAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  store      Store                  @relation(fields: [storeId], references: [id])
  supplier   SupplySupplier         @relation(fields: [supplierId], references: [id])
  items      ProcurementOrderItem[]
  shipments  SupplierShipment[]

  @@index([storeId])
  @@index([supplierId, status])
  @@index([status])
  @@index([createdAt])
}

model ProcurementOrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  productId   Int?
  supplySkuId Int
