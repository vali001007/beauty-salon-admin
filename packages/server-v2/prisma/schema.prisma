model ProductOrder {
  id           Int      @id @default(autoincrement())
  orderNo      String   @unique
  checkoutGroupNo String?
  orderKind    String   @default("product")
  customerId   Int?
  customerName String?
  storeId      Int?
  totalAmount  Decimal  @default(0)
  listAmount   Decimal  @default(0)
  itemDiscountAmount  Decimal @default(0)
  orderDiscountAmount Decimal @default(0)
  totalDiscountAmount Decimal @default(0)
  netAmount           Decimal @default(0)
  discountSource      String  @default("none")
  allocationMethod    String  @default("none")
  promotionId         Int?
  couponId            Int?
  packageId           Int?
  discountPayload     Json?
  status       String   @default("completed")
  payMethod    String?
  source       String?
  items        Json
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer              Customer?                    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  store                 Store?                       @relation(fields: [storeId], references: [id], onDelete: SetNull)
  orderItems            OrderItem[]
  paymentRecords        PaymentRecord[]
  refundRecords         RefundRecord[]
  marketingAttributions MarketingAttribution[]
  pageAttributions      MarketingPageAttribution[]
  recommendationEvents  RecommendationEvent[]
  terminalFollowUpTasks TerminalFollowUpTask[]
  balanceTransactions   CustomerBalanceTransaction[]
  commissionRecords     CommissionRecord[]
  amiPerformanceRecords AmiPerformanceRecord[]
  sourceCustomerCards    CustomerCard[]               @relation("CustomerCardSourceOrder")
  cardUsageSourceRecords CardUsageRecord[]            @relation("CardUsageSourceOrder")

  @@index([status])
  @@index([customerId])
  @@index([storeId])
  @@index([createdAt])
  @@index([storeId, createdAt])
  @@index([checkoutGroupNo])
  @@index([orderKind])
}

model OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      Int
  itemType     String
  itemId       Int?
  name         String
  quantity     Decimal
  unitPrice    Decimal
  listAmount   Decimal  @default(0)
  subtotal     Decimal
  discount     Decimal  @default(0)
  itemDiscountAmount           Decimal @default(0)
  orderAllocatedDiscountAmount Decimal @default(0)
  totalDiscountAmount          Decimal @default(0)
  netAmount                    Decimal @default(0)
  discountSource               String  @default("none")
  allocationMethod             String  @default("none")
  discountPayload              Json?
  isGift                       Boolean @default(false)
  eligibleForOrderDiscount     Boolean @default(true)
  beauticianId Int?
  payload      Json?
  createdAt    DateTime @default(now())

  order             ProductOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  beautician        Beautician?        @relation(fields: [beauticianId], references: [id], onDelete: SetNull)
  commissionRecords CommissionRecord[]
  sourceCustomerCards CustomerCard[]    @relation("CustomerCardSourceOrderItem")
  cardUsageSourceRecords CardUsageRecord[] @relation("CardUsageSourceOrderItem")

  @@index([orderId])
  @@index([itemType, itemId])
  @@index([beauticianId])
}

model PaymentRecord {
  id            Int       @id @default(autoincrement())
