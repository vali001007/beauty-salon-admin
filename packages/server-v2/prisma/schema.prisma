model BeauticianTimeOff {
  id           Int      @id @default(autoincrement())
  storeId      Int
  beauticianId Int
  date         DateTime
  startTime    String
  endTime      String
  reason       String?
  status       String   @default("approved")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  beautician Beautician @relation(fields: [beauticianId], references: [id], onDelete: Cascade)

  @@index([storeId, date])
  @@index([beauticianId, date])
  @@index([status])
}

model SmartSchedulingRun {
  id                 Int       @id @default(autoincrement())
  runId              String    @unique
  storeId            Int
  weekStart          DateTime
  status             String    @default("preview")
  inputSnapshot      Json
  generatedSchedules Json
  score              Int
  warnings           Json?
  createdById        Int?
  confirmedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  store     Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy User? @relation("SmartSchedulingRunCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  schedules Schedule[]

  @@index([storeId, weekStart])
  @@index([status])
}

model BeauticianProjectSkill {
  id           Int      @id @default(autoincrement())
  beauticianId Int
  projectId    Int
  skillLevel   Int      @default(1)
  certified    Boolean  @default(false)
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  beautician Beautician @relation(fields: [beauticianId], references: [id], onDelete: Cascade)
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([beauticianId, projectId])
  @@index([projectId])
}

model StoreResource {
  id        Int      @id @default(autoincrement())
  storeId   Int
  name      String
  type      String
  status    String   @default("active")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  bookings ResourceBooking[]

  @@index([storeId, type, status])
}

model ResourceBooking {
  id         Int      @id @default(autoincrement())
  storeId    Int
  resourceId Int
  date       DateTime
  startTime  String
  endTime    String
  sourceType String
  sourceId   Int?
  status     String   @default("active")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store    Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  resource StoreResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([storeId, date])
  @@index([resourceId, date])
  @@index([sourceType, sourceId])
  @@index([status])
}

model TerminalDevice {
  id              Int                  @id @default(autoincrement())
  storeId         Int
  deviceCode      String               @unique
  activationCode  String
  name            String
  model           String
  status          TerminalDeviceStatus @default(offline)
  appVersion      String?
  firmwareVersion String?
  batteryLevel    Int?
  networkStatus   String?
  printerStatus   String?
  scannerStatus   String?
  cameraStatus    String?
  lastOnlineAt    DateTime?
  boundAt         DateTime?

  store                Store                 @relation(fields: [storeId], references: [id])
  serviceTasks         ServiceTask[]
  skinTests            SkinTest[]
  cardUsageRecords     CardUsageRecord[]
  recommendationEvents RecommendationEvent[]
  followUpTasks        TerminalFollowUpTask[]
  aiAuditLogs          AiAuditLog[]
  cashierShifts        CashierShift[]

  @@index([storeId])
}

model TerminalConversation {
  id           Int      @id @default(autoincrement())
  deviceId     String
  storeId      Int
  role         String
  operatorId   Int?
  date         DateTime @db.Date
  messages     Json
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  archivedAt   DateTime?

  store    Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  operator User?          @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@unique([deviceId, operatorId, role, date])
  @@index([storeId, date])
  @@index([deviceId, date])
  @@index([operatorId, date])
}

model ServiceTask {
  id               Int               @id @default(autoincrement())
  taskNo           String            @unique
  customerId       Int
  projectId        Int
  beauticianId     Int?
  deviceId         Int?
  storeId          Int
  appointmentTime  DateTime
  duration         Int               @default(60)
  status           ServiceTaskStatus @default(pending)
  startedAt        DateTime?
  completedAt      DateTime?
  remark           String?
  consumptionItems Json?
  images           String[]

  store                Store                 @relation(fields: [storeId], references: [id])
  customer             Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project              Project               @relation(fields: [projectId], references: [id])
  beautician           Beautician?           @relation(fields: [beauticianId], references: [id], onDelete: SetNull)
  device               TerminalDevice?       @relation(fields: [deviceId], references: [id])
  skinTests            SkinTest[]
  recommendationEvents RecommendationEvent[]
  followUpTasks        TerminalFollowUpTask[]

  @@index([storeId, status])
  @@index([customerId])
  @@index([beauticianId])
  @@index([deviceId])
}

model SkinTest {
  id                 Int      @id @default(autoincrement())
  customerId         Int?
  taskId             Int?
  deviceId           Int?
  images             String[]
  metrics            Json
  skinType           String
  skinStatus         String?
  mainProblems       String?
  recommendationText String?
  createdAt          DateTime @default(now())

  customer    Customer?       @relation(fields: [customerId], references: [id])
  serviceTask ServiceTask?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  device      TerminalDevice? @relation(fields: [deviceId], references: [id])

  @@index([customerId])
  @@index([taskId])
  @@index([deviceId])
}

// ─── Marketing ───────────────────────────────────────────────────────────────

model MarketingActivity {
  id                     Int       @id @default(autoincrement())
  title                  String
  description            String?
  status                 String    @default("draft")
  participants           Int       @default(0)
  conversion             String?
  startDate              DateTime?
  endDate                DateTime?
  targetCustomers        String?
  discount               String?
  pageSchema             Json?
  sourceRecommendationId String?
  predictionRunId        String?
  audienceSnapshotId     String?
  audienceSnapshotJson   Json?
  sourceSignalsJson      Json?
  offerJson              Json?
  primaryPromotionId     Int?
  promotionIdsJson       Json?
  recommendedItemsJson   Json?
  aiGenerationId         String?
  publishStatus          String?
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  primaryPromotion Promotion? @relation(fields: [primaryPromotionId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([publishStatus])
  @@index([sourceRecommendationId])
  @@index([predictionRunId])
  @@index([primaryPromotionId])
}

model MarketingPage {
  id               Int       @id @default(autoincrement())
  storeId          Int?
  activityId       Int?
  sourceType       String
  sourceId         String?
  title            String
  slug             String    @unique
  runtimeType      String    @default("h5")
  pageSchema       Json
  snapshotJson     Json?
  themeJson        Json?
  shareTitle       String?
  shareDescription String?
  shareImage       String?
  status           String    @default("draft")
  shareUrl         String?
  miniappPath      String?
  qrCodeUrl        String?
  aiGenerationId   String?
  promptVersion    String?
  publishedAt      DateTime?
  offlineAt        DateTime?
  createdBy        Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  versions     MarketingPageVersion[]
  events       MarketingPageEvent[]
  leads        MarketingPageLead[]
  attributions MarketingPageAttribution[]

  @@index([storeId, status])
  @@index([sourceType, sourceId])
  @@index([publishedAt])
}

model MarketingPageVersion {
  id             Int      @id @default(autoincrement())
  pageId         Int
  version        Int
  pageSchema     Json
  snapshotJson   Json?
  changeSummary  String?
  aiGenerationId String?
  createdBy      Int?
  createdAt      DateTime @default(now())

  page MarketingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, version])
  @@index([pageId])
}

model MarketingPageEvent {
  id           Int      @id @default(autoincrement())
  pageId       Int
  storeId      Int?
  customerId   Int?
  sessionId    String?
  openId       String?
  eventType    String
  channel      String?
  referrer     String?
  staffId      Int?
  campaignId   String?
  source       String?
  medium       String?
  userAgent    String?
  ipHash       String?
  metadataJson Json?
  occurredAt   DateTime @default(now())

  page MarketingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, eventType, occurredAt])
  @@index([storeId, occurredAt])
  @@index([customerId])
  @@index([sessionId])
  @@index([channel, occurredAt])
}

model MarketingPageLead {
  id           Int       @id @default(autoincrement())
  pageId       Int
  storeId      Int?
  customerId   Int?
  sessionId    String?
  name         String?
  phone        String
  intentType   String?
  message      String?
  channel      String?
  staffId      Int?
  status       String    @default("new")
  convertedAt  DateTime?
  metadataJson Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  page         MarketingPage              @relation(fields: [pageId], references: [id], onDelete: Cascade)
  attributions MarketingPageAttribution[]

  @@index([pageId, createdAt])
  @@index([storeId, status])
  @@index([phone])
}

model MarketingPageAttribution {
  id                    Int      @id @default(autoincrement())
  leadId                Int
  pageId                Int
  customerId            Int
  orderId               Int
  attributionType       String   @default("last_touch")
  attributedRevenue     Decimal  @default(0)
  attributionWindowDays Int      @default(30)
  touchedAt             DateTime
  convertedAt           DateTime
  createdAt             DateTime @default(now())

  lead     MarketingPageLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  page     MarketingPage     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  customer Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    ProductOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([leadId, orderId])
  @@index([pageId, convertedAt])
  @@index([customerId])
  @@index([orderId])
}

model MarketingAutomationStrategy {
  id             Int                     @id @default(autoincrement())
  name           String
  description    String?
  status         MarketingStrategyStatus @default(draft)
  executionType  String
  source         String                  @default("manual")
  ruleTemplateId Int?
  ruleTemplateVersion String?
  schedule       Json
  triggerRules   Json
  ruleRelation   String                  @default("AND")
  actions        Json
  targetCount    Int                     @default(0)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  lastExecutedAt DateTime?

  executions   MarketingAutomationExecution[]
  touches      MarketingAutomationTouch[]
  attributions MarketingAttribution[]
  ruleTemplate MarketingRuleTemplate? @relation(fields: [ruleTemplateId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([source])
  @@index([ruleTemplateId])
}

model MarketingRuleTemplate {
  id                   Int      @id @default(autoincrement())
  code                 String
  name                 String
  description          String?
  source               String   @default("system")
  category             String
  categoryLabel        String
  scenario             String
  priority             String
  status               String   @default("recommended")
  version              String   @default("1.0.0")
  baseTemplateId       Int?
  storeId              Int?
  triggerType          String
  paramSchema          Json
  defaultParams        Json
  recommendedActions   Json
  scheduleDefault      Json
  frequencyCap         Json
  dataDependencies     Json
  recommendationReason String?
  createdBy            Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  store              Store?                        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  baseTemplate       MarketingRuleTemplate?         @relation("RuleTemplateClone", fields: [baseTemplateId], references: [id], onDelete: SetNull)
  clonedTemplates    MarketingRuleTemplate[]        @relation("RuleTemplateClone")
  automationStrategies MarketingAutomationStrategy[]

  @@unique([code])
  @@index([source])
  @@index([category])
  @@index([scenario])
  @@index([priority])
  @@index([status])
  @@index([storeId])
  @@index([triggerType])
}

model MarketingAutomationExecution {
  id             Int      @id @default(autoincrement())
  strategyId     Int
  strategyName   String
  status         String
  triggeredCount Int      @default(0)
  reachedCount   Int      @default(0)
  channel        String?
  executedAt     DateTime @default(now())
  message        String?

  strategy     MarketingAutomationStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  touches      MarketingAutomationTouch[]
  attributions MarketingAttribution[]

  @@index([strategyId])
}

model PredictionRun {
  id            Int       @id @default(autoincrement())
  storeId       Int?
  modelVersion  String
  status        String    @default("running")
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  customerCount Int       @default(0)
  summaryJson   Json?

  store     Store?                       @relation(fields: [storeId], references: [id], onDelete: SetNull)
  snapshots CustomerPredictionSnapshot[]

  @@index([storeId])
  @@index([modelVersion])
  @@index([startedAt])
  @@index([status])
}

model CustomerPredictionSnapshot {
  id                     Int      @id @default(autoincrement())
  runId                  Int
  customerId             Int
  storeId                Int
  modelVersion           String
  churnScore             Int      @default(0)
  churnLevel             String
  repurchase30dScore     Int      @default(0)
  marketingResponseScore Int      @default(0)
  ltv6m                  Decimal  @default(0)
  ltv12m                 Decimal  @default(0)
  ltvTier                String
  featureJson            Json
  reasonJson             Json
  recommendedActionsJson Json
  createdAt              DateTime @default(now())

  run      PredictionRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  customer Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store    Store                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  touches  MarketingAutomationTouch[]

  @@index([runId])
  @@index([customerId])
  @@index([storeId])
  @@index([churnLevel])
  @@index([ltvTier])
  @@index([createdAt])
}

model MarketingAutomationTouch {
  id                       Int       @id @default(autoincrement())
  executionId              Int
  strategyId               Int
  customerId               Int
  predictionSnapshotId     Int?
  predictedConversionScore Int       @default(0)
  predictedRevenue         Decimal   @default(0)
  channel                  String?
  status                   String    @default("reached")
  touchedAt                DateTime  @default(now())
  convertedAt              DateTime?
  conversionType           String?
  actualRevenue            Decimal?
  attributionWindowDays    Int       @default(30)

  execution          MarketingAutomationExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  strategy           MarketingAutomationStrategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  customer           Customer                     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  predictionSnapshot CustomerPredictionSnapshot?  @relation(fields: [predictionSnapshotId], references: [id], onDelete: SetNull)
  attributions       MarketingAttribution[]

  @@index([executionId])
  @@index([strategyId])
  @@index([customerId])
  @@index([predictionSnapshotId])
  @@index([status])
  @@index([touchedAt])
}

model MarketingAttribution {
  id                    Int      @id @default(autoincrement())
  touchId               Int
  strategyId            Int
  executionId           Int?
  customerId            Int
  orderId               Int
  attributionType       String   @default("last_touch")
  attributedRevenue     Decimal  @default(0)
  attributionWindowDays Int      @default(30)
  occurredAt            DateTime
  createdAt             DateTime @default(now())

  touch     MarketingAutomationTouch      @relation(fields: [touchId], references: [id], onDelete: Cascade)
  strategy  MarketingAutomationStrategy   @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  execution MarketingAutomationExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)
  customer  Customer                      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order     ProductOrder                  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([touchId])
  @@index([strategyId])
  @@index([executionId])
  @@index([customerId])
  @@index([orderId])
  @@index([occurredAt])
}

model RecommendationEvent {
  id               Int      @id @default(autoincrement())
  storeId          Int
  customerId       Int
  deviceId         Int?
  recommendationId Int?
  eventType        String
  taskId           Int?
  orderId          Int?
  note             String?
  payload          Json?
  createdAt        DateTime @default(now())

  store    Store           @relation(fields: [storeId], references: [id])
  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  device   TerminalDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  task     ServiceTask?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  order    ProductOrder?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([customerId])
  @@index([eventType])
  @@index([taskId])
  @@index([orderId])
}

model MarketingRecommendationSnapshot {
  id              Int      @id @default(autoincrement())
  storeId         Int?
  scope           String   @default("customer")
  type            String?
  predictionRunId Int?
  cacheKey        String   @unique
  cardsJson       Json
  cardCount       Int      @default(0)
  sourceVersion   String   @default("rules-v2")
  generatedAt     DateTime @default(now())
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId, scope, type])
  @@index([predictionRunId])
  @@index([generatedAt])
  @@index([expiresAt])
}

model TerminalFollowUpTask {
  id                      Int       @id @default(autoincrement())
  storeId                 Int
  customerId              Int
  recommendationId        Int?
  sourceRecommendationKey String?
  source                  String    @default("recommendation")
  triggerType             String?
  title                   String
  script                  String?
  note                    String?
  priority                String    @default("recommended")
  assigneeRole            String    @default("manager")
  assigneeUserId          Int?
  assigneeBeauticianId    Int?
  assignedByUserId        Int?
  assignedAt              DateTime  @default(now())
  dueAt                   DateTime?
  status                  String    @default("pending")
  resultType              String?
  resultNote              String?
  reservationId           Int?
  orderId                 Int?
  serviceTaskId           Int?
  deviceId                Int?
  completedByUserId       Int?
  completedAt             DateTime?
  payload                 Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer           Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assigneeUser       User?           @relation("FollowUpAssignedUser", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  assigneeBeautician Beautician?     @relation(fields: [assigneeBeauticianId], references: [id], onDelete: SetNull)
  assignedByUser     User?           @relation("FollowUpCreatedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  completedByUser    User?           @relation("FollowUpCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  reservation        Reservation?    @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  order              ProductOrder?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  serviceTask        ServiceTask?    @relation(fields: [serviceTaskId], references: [id], onDelete: SetNull)
  device             TerminalDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([storeId, status, dueAt])
  @@index([storeId, assigneeRole, status, dueAt])
  @@index([storeId, assigneeUserId, status, dueAt])
  @@index([customerId, status])
  @@index([recommendationId, customerId, status])
  @@index([sourceRecommendationKey, customerId, storeId])
  @@index([assigneeBeauticianId])
  @@index([reservationId])
  @@index([orderId])
  @@index([serviceTaskId])
  @@index([deviceId])
  @@index([deletedAt])
}

model CustomerBehaviorEvent {
  id           Int      @id @default(autoincrement())
  storeId      Int
  customerId   Int
  eventType    String
  targetType   String?
  targetId     String?
  sessionId    String?
  metadataJson Json?
  occurredAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([storeId, occurredAt])
  @@index([customerId, occurredAt])
  @@index([eventType])
  @@index([targetType, targetId])
  @@index([sessionId])
}

model CustomerAppIdentity {
  id          Int       @id @default(autoincrement())
  storeId     Int
  customerId  Int?
  openid      String
  unionid     String?
  nickname    String?
  avatarUrl   String?
  phone       String?
  bindStatus  String    @default("unbound")
  source      String    @default("ami_glow")
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  events   CustomerAppEvent[]

  @@unique([storeId, openid])
  @@index([customerId])
  @@index([phone])
  @@index([unionid])
  @@index([bindStatus])
}

model CustomerAppEvent {
  id           Int      @id @default(autoincrement())
  storeId      Int
  customerId   Int?
  identityId   Int?
  openid       String?
  sessionId    String?
  eventType    String
  channel      String?
  targetType   String?
  targetId     String?
  source       String   @default("ami_glow")
  metadataJson Json?
  occurredAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  store    Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  identity CustomerAppIdentity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([storeId, occurredAt])
  @@index([customerId, occurredAt])
  @@index([identityId])
  @@index([openid])
  @@index([eventType])
  @@index([targetType, targetId])
  @@index([channel, occurredAt])
}

model AmiGlowDisplayConfig {
  id            Int       @id @default(autoincrement())
  storeId       Int
  objectType    String
  objectId      Int
  showInAmiGlow Boolean   @default(true)
  sortOrder     Int       @default(0)
  tags          String[]
  bannerImage   String?
  summary       String?
  ctaType       String?
  publishStatus String    @default("published")
  startAt       DateTime?
  endAt         DateTime?
  metadataJson  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, objectType, objectId])
  @@index([storeId, objectType, publishStatus])
  @@index([showInAmiGlow])
  @@index([sortOrder])
  @@map("ami_glow_display_configs")
}

model CustomerBalanceAccount {
  id          Int      @id @default(autoincrement())
  customerId  Int
  storeId     Int
  cashBalance Decimal  @default(0)
  giftBalance Decimal  @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer     Customer                     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store        Store                        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transactions CustomerBalanceTransaction[]

  @@unique([customerId, storeId])
  @@index([storeId])
  @@index([status])
}

model CustomerBalanceTransaction {
  id                Int      @id @default(autoincrement())
  accountId         Int
  customerId        Int
  storeId           Int
  orderId           Int?
  operatorId        Int?
  transactionNo     String   @unique
  type              String
  amount            Decimal
  giftAmount        Decimal  @default(0)
  cashBalanceBefore Decimal  @default(0)
  cashBalanceAfter  Decimal  @default(0)
  giftBalanceBefore Decimal  @default(0)
  giftBalanceAfter  Decimal  @default(0)
  paymentMethod     String?
  remark            String?
  createdAt         DateTime @default(now())

  account  CustomerBalanceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customer Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store    Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order    ProductOrder?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  operator User?                  @relation("BalanceTransactionOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([storeId, createdAt])
  @@index([orderId])
  @@index([operatorId])
  @@index([type])
}

model Promotion {
  id                   Int       @id @default(autoincrement())
  storeId              Int?
  code                 String?
  name                 String
  description          String?
  discountText         String
  type                 String    @default("money_off")
  source               String    @default("store")
  scenario             String?
  audienceTags         Json?
  applicableCustomerLevels Json?
  applicableProjectIds Int[]
  thresholdAmount      Decimal?
  discountAmount       Decimal?
  discountRate         Int?
  giftText             String?
  validDays            Int?
  maxIssueCount        Int?
  issuedCount          Int       @default(0)
  usedCount            Int       @default(0)
  estimatedCost        Decimal?
  grossMarginGuard     Json?
  stackable            Boolean   @default(false)
  approvalStatus       String    @default("approved")
  createdByRecommendationId String?
  metadata             Json?
  startAt              DateTime?
  endAt                DateTime?
  status               String    @default("active")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  marketingActivities MarketingActivity[]

  @@unique([code])
  @@index([storeId])
  @@index([status])
  @@index([type])
  @@index([source])
  @@index([scenario])
  @@index([approvalStatus])
  @@index([startAt, endAt])
}

model PrintJob {
  id           Int       @id @default(autoincrement())
  storeId      Int
  jobNo        String    @unique
  sourceType   String
  sourceId     Int?
  title        String
  content      String
  copies       Int       @default(1)
  status       String
  errorMessage String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt])
  @@index([sourceType, sourceId])
  @@index([status])
}

// ─── Ami Performance & Billing ──────────────────────────────────────────────

model AmiPerformanceRecord {
  id               Int      @id @default(autoincrement())
  storeId          Int
  category         String
  triggerType      String
  triggerId        Int?
  customerId       Int?
  orderId          Int?
  revenueAmount    Decimal?
  commissionRate   Decimal?
  commissionAmount Decimal?
  workMinutes      Int?
  occurredAt       DateTime @default(now())
  settleMonth      String
  metadata         Json?

  store    Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order    ProductOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([storeId, settleMonth])
  @@index([category])
  @@index([customerId])
  @@index([orderId])
  @@index([triggerType, triggerId])
}

model AmiMonthlyBill {
  id               Int      @id @default(autoincrement())
  storeId          Int
  settleMonth      String
  baseFee          Decimal
  commissionFee    Decimal
  totalFee         Decimal
  revenueGenerated Decimal
  roi              Decimal?
  breakdown        Json
  status           String   @default("draft")
  createdAt        DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, settleMonth])
}

// ─── AI Audit ────────────────────────────────────────────────────────────────

model AiAuditLog {
  id             Int      @id @default(autoincrement())
  userId         Int?
  deviceId       Int?
  storeId        Int?
  scenario       String
  promptTemplate String?
  provider       String
  model          String
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  inputSummary   String?
  outputSummary  String?
  safetyBlocked  Boolean  @default(false)
  latencyMs      Int?
  status         String
  createdAt      DateTime @default(now())

  user   User?           @relation(fields: [userId], references: [id])
  device TerminalDevice? @relation(fields: [deviceId], references: [id])
  store  Store?          @relation(fields: [storeId], references: [id])

  @@index([userId])
  @@index([deviceId])
  @@index([storeId])
  @@index([scenario])
  @@index([createdAt])
}

// ─── Agent Runtime ──────────────────────────────────────────────────────────

model AgentDefinition {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  roleScope   Json?
  configJson  Json?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@map("agent_definitions")
}

model AgentRun {
  id           Int       @id @default(autoincrement())
  runNo        String    @unique
  storeId      Int
  userId       Int?
  deviceId     Int?
  role         String
  entrypoint   String    @default("api")
  agentCode    String
  status       String
  userInput    String
  planJson     Json?
  contextJson  Json?
  evidenceJson Json?
  resultJson   Json?
  errorMessage String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([storeId, createdAt])
  @@index([userId])
  @@index([deviceId])
  @@index([status])
  @@index([agentCode])
  @@map("agent_runs")
}

model AgentMessage {
  id        Int      @id @default(autoincrement())
  runId     Int
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([runId, createdAt])
  @@map("agent_messages")
}

model AgentStep {
  id         Int       @id @default(autoincrement())
  runId      Int
  stepType   String
  name       String
  status     String
  inputJson  Json?
  outputJson Json?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  @@index([runId, startedAt])
  @@index([status])
  @@map("agent_steps")
}

model AgentToolCall {
  id             Int       @id @default(autoincrement())
  runId          Int
  toolName       String
  riskLevel      String
  status         String
  argsJson       Json
  resultJson     Json?
  approvalId     Int?
  idempotencyKey String?
  latencyMs      Int?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([runId, createdAt])
  @@index([toolName])
  @@index([riskLevel])
  @@index([status])
  @@index([approvalId])
  @@map("agent_tool_calls")
}

model AgentApproval {
  id         Int       @id @default(autoincrement())
  runId      Int
  toolCallId Int?
  status     String
  requestedBy Int?
  approvedBy Int?
  beforeJson Json?
  afterJson  Json?
  comment    String?
  createdAt  DateTime  @default(now())
  decidedAt  DateTime?

  @@index([runId, createdAt])
  @@index([toolCallId])
  @@index([status])
  @@map("agent_approvals")
}

model AgentEvalCase {
  id              Int      @id @default(autoincrement())
  scenario        String
  input           String
  role            String
  expectedTool    String?
  expectedOutcome Json?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scenario])
  @@index([status])
  @@map("agent_eval_cases")
}

model AgentEvalRun {
  id         Int      @id @default(autoincrement())
  caseId     Int?
  runId      Int?
  status     String
  score      Decimal?
  resultJson Json?
  errorMessage String?
  createdAt  DateTime @default(now())

  @@index([caseId])
  @@index([runId])
  @@index([status])
  @@map("agent_eval_runs")
}
