  ownerId                   String?
  status                    BusinessDefinitionStatus @default(active)
  currentPublishedVersionId Int?                     @unique
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  versions                BusinessDefinitionVersion[] @relation("BusinessDefinitionVersions")
  currentPublishedVersion BusinessDefinitionVersion?  @relation("BusinessDefinitionCurrentPublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: SetNull)
  semanticEvidence        BusinessSemanticEvidence[]
  aliasCandidates         BusinessDefinitionAliasCandidate[]

  @@unique([kind, definitionKey])
  @@index([domain, kind, status])
  @@map("business_definition")
}

model BusinessDefinitionVersion {
  id                 Int                                @id @default(autoincrement())
  definitionId       Int
  version            Int
  schemaVersion      String                             @default("1.0")
  payload            Json
  lifecycleStatus    BusinessDefinitionLifecycleStatus @default(draft)
  fingerprint        String
  sourceFingerprint  String
  validationStatus   BusinessDefinitionValidationStatus @default(pending)
  validationReport   Json?
  canonicalQueryRef  String?
  fixtureSetKey      String?
  timezone           String                             @default("Asia/Shanghai")
  storeScope         Json
  createdBy          Int
  validatedBy        Int?
  validatedAt        DateTime?
  publishedBy        Int?
  publishedAt        DateTime?
  createdAt          DateTime                           @default(now())

  definition                 BusinessDefinition             @relation("BusinessDefinitionVersions", fields: [definitionId], references: [id], onDelete: Cascade)
  currentForDefinition        BusinessDefinition?            @relation("BusinessDefinitionCurrentPublishedVersion")
  evidence                    BusinessDefinitionEvidence[]
  projections                 BusinessDefinitionProjection[]
  brainOntologyEntities       BrainOntologyEntity[]           @relation("BrainOntologyEntityBusinessDefinitionVersion")
  brainOntologyRelations      BrainOntologyRelation[]         @relation("BrainOntologyRelationBusinessDefinitionVersion")
  brainMetrics                BrainMetric[]                   @relation("BrainMetricBusinessDefinitionVersion")
  brainDimensions             BrainDimension[]                @relation("BrainDimensionBusinessDefinitionVersion")
  brainEvalCases              BrainEvalCase[]                 @relation("BrainEvalCaseBusinessDefinitionVersion")
  semanticEvidence            BusinessSemanticEvidence[]
  aliasCandidates             BusinessDefinitionAliasCandidate[] @relation("BusinessDefinitionAliasCandidateSourceVersion")
  aliasCandidateDrafts        BusinessDefinitionAliasCandidate[] @relation("BusinessDefinitionAliasCandidateDraftVersion")
  aliasCandidatePublications  BusinessDefinitionAliasCandidate[] @relation("BusinessDefinitionAliasCandidatePublishedVersion")

  @@unique([definitionId, version])
  @@unique([definitionId, fingerprint])
  @@unique([id, definitionId])
  @@index([lifecycleStatus, validationStatus])
  @@index([sourceFingerprint])
  @@map("business_definition_version")
}

model BusinessDefinitionEvidence {
  id                  Int      @id @default(autoincrement())
  versionId           Int
  sourceType          String
  sourcePath          String
  sourceSymbol        String?
  lineStart           Int?
  lineEnd             Int?
  evidenceKind        String
  evidenceFingerprint String
  confidence          Float
  conflictGroup       String?
  createdAt           DateTime @default(now())

  version BusinessDefinitionVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, evidenceFingerprint])
  @@index([sourceType, sourcePath])
  @@index([conflictGroup])
  @@map("business_definition_evidence")
}

model BusinessSemanticEvidence {
  id                     Int      @id @default(autoincrement())
  sourceType             String   @db.VarChar(40)
  evidenceKind           String   @db.VarChar(40)
  runId                  Int?
  storeId                Int
  userId                 Int
  definitionId           Int
  definitionVersionId    Int
  definitionType         String   @db.VarChar(40)
  definitionKey          String   @db.VarChar(160)
  definitionVersion      Int
  definitionFingerprint  String   @db.VarChar(64)
  definitionSourceFingerprint String @db.VarChar(64)
  redactedText           String   @db.VarChar(1000)
  normalizedValue        String   @db.VarChar(256)
  confidence             Float
  status                 String   @default("pooled") @db.VarChar(32)
  idempotencyFingerprint String   @unique @db.VarChar(64)
  firstSeenAt            DateTime @default(now())
  lastSeenAt             DateTime @default(now())
  metadata               Json?
  aliasCandidateId       Int?

  run               BrainRun?                 @relation(fields: [runId], references: [id], onDelete: SetNull)
  definition        BusinessDefinition        @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  definitionVersionRecord BusinessDefinitionVersion @relation(fields: [definitionVersionId, definitionId], references: [id, definitionId], onDelete: Restrict)
  aliasCandidate    BusinessDefinitionAliasCandidate? @relation(fields: [aliasCandidateId, definitionId], references: [id, definitionId], onDelete: Restrict)

  @@index([definitionType, definitionKey, normalizedValue, status])
  @@index([definitionVersionId])
  @@index([runId])
  @@index([aliasCandidateId])
  @@index([storeId, userId, firstSeenAt])
  @@map("business_semantic_evidence")
}

model BusinessDefinitionAliasCandidate {
  id                      Int      @id @default(autoincrement())
  definitionId            Int
  versionId               Int
  definitionType          String   @db.VarChar(40)
  definitionKey           String   @db.VarChar(160)
  alias                    String   @db.VarChar(256)
  normalizedAlias         String   @db.VarChar(256)
  occurrenceCount         Int      @default(0)
  distinctUserCount       Int      @default(0)
  averageConfidence       Float    @default(0)
  explicitCorrectionCount Int      @default(0)
  maxExplicitConfidence   Float    @default(0)
  conflictDefinitions     Json     @default("[]")
  regressionCaseIds       Json     @default("[]")
  status                  String   @default("pending") @db.VarChar(32)
  blockReason             String?  @db.VarChar(1000)
  evalReport              Json?
  draftVersionId          Int?
  publishedVersionId      Int?
  attemptCount            Int      @default(0)
  leaseOwner              String?  @db.VarChar(160)
  leaseExpiresAt          DateTime?
  firstSeenAt             DateTime @default(now())
  lastSeenAt              DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  definition       BusinessDefinition        @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  version          BusinessDefinitionVersion @relation("BusinessDefinitionAliasCandidateSourceVersion", fields: [versionId, definitionId], references: [id, definitionId], onDelete: Restrict)
  draftVersion     BusinessDefinitionVersion? @relation("BusinessDefinitionAliasCandidateDraftVersion", fields: [draftVersionId, definitionId], references: [id, definitionId], onDelete: Restrict)
  publishedVersion BusinessDefinitionVersion? @relation("BusinessDefinitionAliasCandidatePublishedVersion", fields: [publishedVersionId, definitionId], references: [id, definitionId], onDelete: Restrict)
  evidence         BusinessSemanticEvidence[]

  @@unique([definitionId, normalizedAlias])
  @@unique([id, definitionId])
  @@index([definitionId, versionId])
  @@index([status, leaseExpiresAt])
  @@index([draftVersionId])
  @@index([publishedVersionId])
  @@map("business_definition_alias_candidate")
}

model BusinessDefinitionProjection {
