  store         Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([status])
  @@index([sortOrder])
}

model CustomerCard {
  id             Int      @id @default(autoincrement())
  customerId     Int
  cardId         Int
  operatorId     Int?
  sourceOrderId  Int?
  sourceOrderItemId Int?
  cardName       String
  totalTimes     Int
  remainingTimes Int
