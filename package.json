{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "npm --prefix packages/server-v2 run dev",
    "dev:marketing-h5": "npm --prefix packages/marketing-h5 run dev",
    "dev:full": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "build:marketing-h5": "npm --prefix packages/marketing-h5 run build",
    "preview:marketing-h5": "npm --prefix packages/marketing-h5 run preview",
    "start:api": "npm --prefix packages/server-v2 run start:prod",
    "check:api": "npm --prefix packages/server-v2 run build",
    "db:migrate:v2": "npm --prefix packages/server-v2 run db:migrate",
    "db:generate:v2": "npm --prefix packages/server-v2 run db:generate",
    "db:seed:demo": "npm --prefix packages/server-v2 run db:seed:mvp",
    "db:seed:demo-full": "npm --prefix packages/server-v2 run db:seed:demo-full",
    "db:seed:demo-full:dry-run": "npm --prefix packages/server-v2 run db:seed:demo-full:dry-run",
    "db:studio:v2": "npm --prefix packages/server-v2 run db:studio",
    "check:no-runtime-mock": "node scripts/check-no-runtime-mock-boundary.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
