{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node", "@testing-library/jest-dom"]
  },
  "include": [
    "src/test/**/*.ts",
    "src/test/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "packages/agent-core/**/*.test.ts",
    "packages/agent-core/**/*.test.tsx",
    "packages/agent-core/**/*.spec.ts",
    "packages/agent-core/**/*.spec.tsx",
    "src/vite-env.d.ts"
  ]
}
